{
  "name": "acme",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,astro,js,json}\"",
    "check-types": "turbo run check-types",
    "zero-cache": "zero-cache-dev -p packages/zero/src/index.ts --log-level debug"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.6.2",
    "@rocicorp/zero": "0.22.2025081300",
    "prettier": "3.6.2",
    "turbo": "2.5.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.14.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "@rocicorp/zero-sqlite3"
    ]
  }
}
